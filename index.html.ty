<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dell OptiPlex 7050 SFF | Thank You</title>
    
   

    <style>
        /* --- Shared Styles (Copied from Optiplex 7050 sff Updated.html) --- */
        * { 
            margin: 0; 
            padding: 0; 
            box-sizing: border-box; 
            cursor: none !important;
        }

        /* Reinforce cursor hiding on all interactive elements and states */
        a, button, *:active {
            cursor: none !important;
        }

        html { scrollbar-width: none; -ms-overflow-style: none; scroll-behavior: smooth; }
        html::-webkit-scrollbar { display: none; }

        html.no-smooth { scroll-behavior: auto !important; }
        body.is-dragging { user-select: none; }

        :root {
            --bg: #050505;
            --dell-blue: #0076ce;
            --neon-green: #39ff14; /* Gen Alpha 'Aesthetic' */
            --glass: rgba(255, 255, 255, 0.05);
            --text-main: #ffffff;
            --text-dim: #b0b0b0;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: transparent; /* Allow canvas to be visible */
            color: var(--text-main);
            overflow: hidden; /* Prevent scrolling to keep it a single landing page */
        }

        h1 { font-size: clamp(3rem, 8vw, 6rem); font-weight: 900; letter-spacing: -2px; }
        h2 { font-size: clamp(2rem, 5vw, 3.5rem); }

        .container { max-width: 1300px; margin: 0 auto; padding: 0 20px; }

        /* Navigation Bar */
        .nav-bar {
            background: rgba(0,0,0,0.8);
            padding: 20px 0;
            text-align: center;
            position: sticky;
            top: 0;
            z-index: 1000;
            border-bottom: 1px solid #111;
        }
        .nav-bar a {
            color: white; text-decoration: none; margin: 0 15px; font-weight: 700; transition: color 0.3s;
        }
        .nav-bar a:hover { color: var(--dell-blue); }

        /* Custom Cursor Style */
        .custom-cursor {
            width: 20px;
            height: 20px;
            border: 2px solid var(--dell-blue);
            background-color: black;
            border-radius: 50%;
            position: fixed;
            pointer-events: none;
            z-index: 10000;
            transform: translate(-50%, -50%);
            transition: background-color 0.1s, border-color 0.1s, opacity 0.2s;
            opacity: 0;
        }
        .custom-cursor.flash {
            background-color: white;
            border-color: white;
        }

        /* Particle Background Canvas */
        #particle-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            background-color: var(--bg);
            pointer-events: none;
            will-change: transform;
        }

        /* --- Thank You Page Specific Styles --- */
        #thankyou-section {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            height: calc(100vh - 72px); /* Full height minus navbar */
            text-align: center;
        }

        #thankyou-section h2 {
            font-size: clamp(2.5rem, 6vw, 4.5rem);
            margin-bottom: 20px;
        }

        #thankyou-section p {
            font-size: 1.5rem;
            color: var(--text-dim);
            max-width: 800px;
            margin-bottom: 40px;
        }

        .home-btn {
            background: var(--dell-blue);
            color: white;
            padding: 15px 30px;
            border-radius: 30px;
            font-weight: 700;
            text-decoration: none;
            transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 10px 25px rgba(0, 118, 206, 0.4);
            border: none;
            font-size: 1rem;
            text-transform: uppercase;
            cursor: pointer;
        }

        .home-btn:hover {
            transform: translateY(-3px);
            background: #005da3;
            box-shadow: 0 15px 30px rgba(0, 118, 206, 0.6);
        }
    </style>
</head>
<body>

    <div class="nav-bar">
        <a href="Optiplex 7050 sff Updated.html">Home</a>
        <a href="about.html">About Us</a>
        <a href="tictactoe.html">Play Game</a>
        <a href="contact.html">Contact</a>
        <a href="digital-ocarina.html">Ocarina</a>
    </div>

    <canvas id="particle-canvas"></canvas>

    <section id="thankyou-section">
        <div class="container">
            <h2>Thank You for Your <span style="color:var(--dell-blue)">Message!</span></h2>
            <p>We appreciate you reaching out. We'll get back to you as soon as possible.</p>
            <a href="Optiplex 7050 sff Updated.html" class="home-btn">Return to Home</a>
        </div>
    </section>

    <script>
        // Particle Background Logic (Copied from Optiplex 7050 sff Updated.html)
        const canvas = document.getElementById('particle-canvas');
        const ctx = canvas.getContext('2d');
        let particles = [];
        let mouse = { x: null, y: null };
        let isLowPowerMode = false;
        let animationId = null;

        function initPowerManagement() {
            const updatePowerStatus = (battery = null) => {
                const isHidden = document.hidden;
                const isLowBattery = battery ? (battery.level <= 0.2 && !battery.charging) : false;
                
                const prevMode = isLowPowerMode;
                isLowPowerMode = isHidden || isLowBattery;

                if (prevMode && !isLowPowerMode && !animationId) {
                    animateParticles();
                }
            };

            document.addEventListener('visibilitychange', () => updatePowerStatus());

            if ('getBattery' in navigator) {
                navigator.getBattery().then(battery => {
                    battery.addEventListener('levelchange', () => updatePowerStatus(battery));
                    battery.addEventListener('chargingchange', () => updatePowerStatus(battery));
                    updatePowerStatus(battery);
                }).catch(() => updatePowerStatus());
            } else { updatePowerStatus(); }
        }

        function initParticles() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
            particles = [];
            const particleCount = Math.min(Math.floor((canvas.width * canvas.height) / 25000), 100);
            for (let i = 0; i < particleCount; i++) {
                particles.push({
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height,
                    vx: (Math.random() - 0.5) * 0.5,
                    vy: (Math.random() - 0.5) * 0.5,
                    size: Math.random() * 1.5 + 0.5
                });
            }
        }

        function animateParticles() {
            if (isLowPowerMode) {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                animationId = null;
                return;
            }

            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            const connectionLimitSq = 150 * 150;
            ctx.fillStyle = 'rgba(0, 118, 206, 0.4)';
            
            particles.forEach(p => {
                if (mouse.x !== null && mouse.y !== null) {
                    const dx = p.x - mouse.x;
                    const dy = p.y - mouse.y;
                    const distance = Math.sqrt(dx * dx + dy * dy);
                    const forceRadius = 120;
                    if (distance < forceRadius) {
                        const force = (forceRadius - distance) / forceRadius;
                        p.x += (dx / distance) * force * 5;
                        p.y += (dy / distance) * force * 5;
                    }
                }

                p.x += p.vx;
                p.y += p.vy;

                if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
                if (p.y < 0 || p.y > canvas.height) p.vy *= -1;

                ctx.beginPath();
                ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
                ctx.fill();
            });
            
            ctx.strokeStyle = 'rgba(0, 118, 206, 0.1)';
            ctx.lineWidth = 0.5;
            ctx.beginPath();
            for (let i = 0; i < particles.length; i++) {
                for (let j = i + 1; j < particles.length; j++) {
                    const dx = particles[i].x - particles[j].x;
                    const dy = particles[i].y - particles[j].y;
                    const distSq = dx * dx + dy * dy;
                    if (distSq < connectionLimitSq) {
                        ctx.moveTo(particles[i].x, particles[i].y);
                        ctx.lineTo(particles[j].x, particles[j].y);
                    }
                }
            }
            ctx.stroke();
            animationId = requestAnimationFrame(animateParticles);
        }

        window.addEventListener('resize', initParticles);
        initPowerManagement();
        initParticles();
        animateParticles();

        // Custom Cursor Implementation (Copied from Optiplex 7050 sff Updated.html)
        const cursor = document.createElement('div');
        cursor.classList.add('custom-cursor');
        document.body.appendChild(cursor);

        document.addEventListener('mousemove', (e) => {
            cursor.style.left = e.clientX + 'px';
            cursor.style.top = e.clientY + 'px';
            cursor.style.opacity = '1';
            mouse.x = e.clientX;
            mouse.y = e.clientY;
        });

        document.addEventListener('mousedown', () => cursor.classList.add('flash'));
        document.addEventListener('mouseup', () => cursor.classList.remove('flash'));

        document.addEventListener('mouseleave', () => {
            cursor.style.opacity = '0';
            mouse.x = null;
            mouse.y = null;
        });
    </script>
</body>
</html>
